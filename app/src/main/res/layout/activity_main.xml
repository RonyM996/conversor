<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:backgroundTint="?android:attr/windowBackgroundFallback"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:text="Conversor"
        android:textSize="24sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="318dp"
        android:layout_height="81dp"
        android:autofillHints="name"
        android:backgroundTint="#D72020"
        android:breakStrategy="balanced"
        android:hint="@string/ingresa_el_monto"
        android:hyphenationFrequency="normal"
        android:inputType="numberDecimal"
        android:textColor="#000000"
        android:textColorHighlight="#121111"
        android:textColorHint="#161414" />

    <TextView
        android:layout_width="328dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/selecciona_moneda_origen" />

    <Spinner
        android:id="@+id/spinnerFrom"
        android:layout_width="334dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="#EBEBEB"
        android:foregroundTint="#FFF7F7"
        android:minHeight="48dp" />

    <Button
        android:id="@+id/btnConvertir"
        android:layout_width="232dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/convertir_a_usd" />

    <Button
        android:id="@+id/btnVerHistorial"
        android:layout_width="252dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/ver_historial" />

</LinearLayout>